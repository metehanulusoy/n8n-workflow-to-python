{
  "name": "Slack Daily Alert",
  "nodes": [
    {
      "id": "1",
      "name": "Every Day at 9am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [200, 300],
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 24 }]
        }
      }
    },
    {
      "id": "2",
      "name": "Get Weather",
      "type": "n8n-nodes-base.httpRequest",
      "position": [400, 300],
      "parameters": {
        "method": "GET",
        "url": "https://wttr.in/Istanbul?format=3"
      }
    },
    {
      "id": "3",
      "name": "Send to Slack",
      "type": "n8n-nodes-base.slack",
      "position": [600, 300],
      "parameters": {
        "channel": "#general",
        "text": "Good morning! Here is today's weather update."
      }
    }
  ],
  "connections": {
    "Every Day at 9am": {
      "main": [[{ "node": "Get Weather", "type": "main", "index": 0 }]]
    },
    "Get Weather": {
      "main": [[{ "node": "Send to Slack", "type": "main", "index": 0 }]]
    }
  }
}
